{
  "name": "stash",
  "version": "0.1.1",
  "description": "Minimal clipboard history with drag-and-drop to any app",
  "main": "src/main.js",
  "author": "HariKrish",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac --x64 --arm64 --publish never",
    "dist:win": "electron-builder --win --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.harikrish.stash",
    "productName": "Stash",
    "artifactName": "${productName}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ]
  }
}
